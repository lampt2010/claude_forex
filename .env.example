# ============================================================
# Forex Trading Bot — Environment Variables Template
# Bot Giao Dịch Forex — Mẫu Biến Môi Trường
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real credentials
# 3. NEVER commit .env to version control!
# ============================================================

# ── MetaTrader 5 Account / Tài khoản MetaTrader 5 ───────────
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=Exness-MT5Trial6

# ── LLM API Keys / Khóa API LLM ─────────────────────────────
# Only fill the provider you selected in config.yaml
# Chỉ điền nhà cung cấp bạn đã chọn trong config.yaml

# OpenAI (provider: openai)
OPENAI_API_KEY=sk-...

# Anthropic Claude (provider: anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (provider: groq)
GROQ_API_KEY=gsk_...

# ── Telegram Bot (optional) / Bot Telegram (tùy chọn) ────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# ── Optional overrides / Ghi đè tùy chọn ────────────────────
# Uncomment to override config.yaml values
# Bỏ ghi chú để ghi đè giá trị config.yaml

# RISK_PERCENT=1.0
# MAX_DAILY_LOSS_PERCENT=5.0
# INTERVAL_MINUTES=15
